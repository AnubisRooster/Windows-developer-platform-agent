# =============================================================================
# Developer AI Platform - Environment Configuration
# =============================================================================

# IronClaw Runtime (Rust reasoning engine on port 3000)
IRONCLAW_URL=http://localhost:3000
IRONCLAW_TIMEOUT=30

# OpenRouter / LLM (fallback when IronClaw is unavailable)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/hunter-alpha
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenAI (for embeddings or as alternative LLM)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Embeddings
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_CHUNK_SIZE=1000
EMBEDDING_CHUNK_OVERLAP=200

# Ollama (local embeddings alternative)
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# Slack
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_APP_TOKEN=xapp-your-token
SLACK_SIGNING_SECRET=your-signing-secret

# GitHub
GITHUB_TOKEN=ghp_your_token
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Jira
JIRA_URL=https://your-org.atlassian.net
JIRA_USER=your-email@example.com
JIRA_API_TOKEN=your-jira-token
JIRA_WEBHOOK_SECRET=your-jira-webhook-secret

# Confluence
CONFLUENCE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_USER=your-email@example.com
CONFLUENCE_API_TOKEN=your-confluence-token

# Jenkins
JENKINS_URL=https://jenkins.your-org.com
JENKINS_USER=admin
JENKINS_API_TOKEN=your-jenkins-token
JENKINS_WEBHOOK_SECRET=your-jenkins-webhook-secret

# Gmail
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# Microsoft Outlook (Microsoft Graph API OAuth2 token)
OUTLOOK_ACCESS_TOKEN=

# Zoho Mail
ZOHO_ACCESS_TOKEN=
ZOHO_ACCOUNT_ID=

# X (Twitter) API v2
X_BEARER_TOKEN=

# LinkedIn (OAuth2 access token)
LINKEDIN_ACCESS_TOKEN=

# Server
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=8080

# Cloudflare Tunnel (public URL for webhook delivery)
# Quick tunnel: cloudflared tunnel --url http://localhost:8080
# Named tunnel: cloudflared tunnel run dev-ai-platform
WEBHOOK_BASE_URL=https://webhooks.your-domain.com

# Database (PostgreSQL primary, SQLite fallback)
DATABASE_URL=postgresql://claw:claw@localhost:5432/clawagent
SQL_ECHO=false

# Redis (event bus queue)
REDIS_URL=redis://localhost:6379/0
